{
  "access_levels": [],
  "arn": "arn:aws:iam::aws:policy/AWSQuickSetupPatchPolicyTagManagementExecutionPolicy",
  "createdate": "2026-06-03T14:12:13+00:00",
  "credentials_exposure": false,
  "data_access": false,
  "deprecated": false,
  "document": {
    "Statement": [
      {
        "Action": [
          "ssm:GetInventory"
        ],
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "GetSSMInventory"
      },
      {
        "Action": [
          "ssm:AddTagsToResource",
          "ssm:RemoveTagsFromResource"
        ],
        "Condition": {
          "ForAllValues:StringLike": {
            "aws:TagKeys": "QSConfigName-*"
          },
          "ForAnyValue:StringLike": {
            "aws:TagKeys": "QSConfigName-*"
          }
        },
        "Effect": "Allow",
        "Resource": "arn:aws:ssm:*:*:managed-instance/*",
        "Sid": "ManageSSMManagedInstanceTags"
      },
      {
        "Action": [
          "ec2:CreateTags",
          "ec2:DeleteTags"
        ],
        "Condition": {
          "ForAllValues:StringLike": {
            "aws:TagKeys": "QSConfigName-*"
          },
          "ForAnyValue:StringLike": {
            "aws:TagKeys": "QSConfigName-*"
          }
        },
        "Effect": "Allow",
        "Resource": "arn:aws:ec2:*:*:instance/*",
        "Sid": "ManageEC2InstanceTags"
      }
    ],
    "Version": "2012-10-17"
  },
  "effective_actions": [],
  "grantless": false,
  "malformed": false,
  "name": "AWSQuickSetupPatchPolicyTagManagementExecutionPolicy",
  "privesc": false,
  "resource_exposure": false,
  "undocumented_actions": false,
  "unknown_actions": [
    {
      "action": "ssm:GetInventory",
      "condition": null
    },
    {
      "action": "ssm:AddTagsToResource",
      "condition": {
        "ForAllValues:StringLike": {
          "aws:TagKeys": "QSConfigName-*"
        },
        "ForAnyValue:StringLike": {
          "aws:TagKeys": "QSConfigName-*"
        }
      }
    },
    {
      "action": "ssm:RemoveTagsFromResource",
      "condition": {
        "ForAllValues:StringLike": {
          "aws:TagKeys": "QSConfigName-*"
        },
        "ForAnyValue:StringLike": {
          "aws:TagKeys": "QSConfigName-*"
        }
      }
    },
    {
      "action": "ec2:CreateTags",
      "condition": {
        "ForAllValues:StringLike": {
          "aws:TagKeys": "QSConfigName-*"
        },
        "ForAnyValue:StringLike": {
          "aws:TagKeys": "QSConfigName-*"
        }
      }
    },
    {
      "action": "ec2:DeleteTags",
      "condition": {
        "ForAllValues:StringLike": {
          "aws:TagKeys": "QSConfigName-*"
        },
        "ForAnyValue:StringLike": {
          "aws:TagKeys": "QSConfigName-*"
        }
      }
    }
  ],
  "updatedate": "2026-06-03T14:12:13+00:00",
  "version": "v1"
