{
  "access_levels": [],
  "arn": "arn:aws:iam::aws:policy/AmazonSageMakerSpacesRouterPolicy",
  "createdate": "2026-02-12T17:58:24+00:00",
  "credentials_exposure": false,
  "data_access": false,
  "deprecated": false,
  "document": {
    "Statement": [
      {
        "Action": [
          "kms:DescribeKey"
        ],
        "Effect": "Allow",
        "Resource": "arn:aws:kms:*:*:key/*",
        "Sid": "KMSDescribeKey"
      },
      {
        "Action": [
          "kms:GenerateDataKey",
          "kms:Decrypt"
        ],
        "Condition": {
          "StringEquals": {
            "kms:EncryptionContext:sagemaker:component": "amazon-sagemaker-spaces",
            "kms:EncryptionContext:sagemaker:eks-cluster-arn": "${aws:PrincipalTag/eks-cluster-arn}"
          }
        },
        "Effect": "Allow",
        "Resource": "arn:aws:kms:*:*:key/*",
        "Sid": "KMSKeyOperations"
      }
    ],
    "Version": "2012-10-17"
  },
  "effective_actions": [],
  "grantless": false,
  "malformed": false,
  "name": "AmazonSageMakerSpacesRouterPolicy",
  "privesc": false,
  "resource_exposure": false,
  "undocumented_actions": false,
  "unknown_actions": [
    {
      "action": "kms:DescribeKey",
      "condition": null
    },
    {
      "action": "kms:GenerateDataKey",
      "condition": {
        "StringEquals": {
          "kms:EncryptionContext:sagemaker:component": "amazon-sagemaker-spaces",
          "kms:EncryptionContext:sagemaker:eks-cluster-arn": "${aws:PrincipalTag/eks-cluster-arn}"
        }
      }
    },
    {
      "action": "kms:Decrypt",
      "condition": {
        "StringEquals": {
          "kms:EncryptionContext:sagemaker:component": "amazon-sagemaker-spaces",
          "kms:EncryptionContext:sagemaker:eks-cluster-arn": "${aws:PrincipalTag/eks-cluster-arn}"
        }
      }
    }
  ],
  "updatedate": "2026-02-12T17:58:24+00:00",
  "version": "v3"
