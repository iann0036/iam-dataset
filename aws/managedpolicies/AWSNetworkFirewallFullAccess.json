        "Sid": "NetworkFirewallLoggingCWL"
      },
      {
        "Action": [
          "s3:GetBucketPolicy",
          "s3:PutBucketPolicy"
        ],
        "Condition": {
          "StringEquals": {
            "aws:ResourceAccount": "${aws:PrincipalAccount}"
          }
        },
        "Effect": "Allow",
        "Resource": "arn:aws:s3:::*",
        "Sid": "NetworkFirewallLoggingS3"
      },
      {
