          "arn:aws:waf-regional:*:*:bytematchset/*",
          "arn:aws:waf-regional:*:*:ipset/*",
          "arn:aws:waf-regional:*:*:ratebasedrule/*",
          "arn:aws:waf-regional:*:*:rule/*",
