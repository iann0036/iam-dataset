          "arn:aws:wafv2:*:*:*/managedruleset/*/*",
          "arn:aws:wafv2:*:*:*/rulegroup/*/*",
          "arn:aws:wafv2:*:*:*/regexpatternset/*/*"
        ],
        "Sid": "AllowReadOnlyOfAWSWAF"
      },
