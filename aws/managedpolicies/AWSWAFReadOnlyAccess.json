          "bedrock-agentcore:GatewayListResourcesForWebACL"
        ],
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "AllowListActionsForAgentCoreGateway"
      }
    ],
    "Version": "2012-10-17"
  },
