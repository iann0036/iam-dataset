            "aws:ResourceTag/BedrockAgentCoreIdentityManaged": "true"
          }
        },
        "Effect": "Allow",
        "Resource": [
          "arn:aws:vpc-lattice:*:*:resourcegateway/*"
        ],
        "Sid": "AllowResourceGatewayCreate"
      },
      {
