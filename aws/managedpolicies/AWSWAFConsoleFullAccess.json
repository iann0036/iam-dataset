        "Action": [
          "appsync:ListGraphqlApis",
          "appsync:ListApis",
          "appsync:ListResourcesForWebACL"
        ],
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "AllowListActionsForAppSync"
      },
      {
        "Action": [
          "cognito-idp:AssociateWebACL",
          "cognito-idp:DisassociateWebACL",
