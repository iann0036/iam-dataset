          "arn:aws:s3:::aws-waf-logs-*"
        ],
        "Sid": "GrantLogDeliveryPermissionForS3Bucket"
      },
      {
        "Action": [
          "logs:PutResourcePolicy"
        ],
        "Condition": {
          "ForAnyValue:StringEquals": {
            "aws:CalledVia": [
              "wafv2.amazonaws.com"
            ]
          }
        },
        "Effect": "Allow",
        "Resource": "*",
