  "document": {
    "Statement": [
      {
        "Action": [
          "s3:PutObject",
          "s3:GetObject",
          "s3:ListBucket"
        ],
        "Condition": {
          "StringEquals": {
            "aws:ResourceAccount": "${aws:PrincipalAccount}"
          }
        },
        "Effect": "Allow",
        "Resource": "arn:aws:s3:::amazon-braket-*"
      },
      {
        "Action": [
          "s3:PutObject",
          "s3:GetObject",
          "s3:ListBucket"
        ],
        "Condition": {
          "StringEquals": {
            "aws:ResourceAccount": "${aws:PrincipalAccount}"
          },
          "StringEqualsIgnoreCase": {
            "aws:ResourceTag/AmazonBraket": "true"
          }
        },
        "Effect": "Allow",
        "Resource": "arn:aws:s3:::*"
      },
      {
        "Action": [
