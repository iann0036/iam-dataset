          "logs:CreateLogGroup",
          "logs:DescribeLogGroups"
        ],
        "Condition": {
          "StringEquals": {
            "aws:ResourceAccount": "${aws:PrincipalAccount}"
          }
        },
        "Effect": "Allow",
        "Resource": "arn:aws:logs:*:*:log-group:/aws/braket:*"
      }
    ],
    "Version": "2012-10-17"
  },
