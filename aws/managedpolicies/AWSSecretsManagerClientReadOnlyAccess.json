{
  "access_levels": [],
  "arn": "arn:aws:iam::aws:policy/AWSSecretsManagerClientReadOnlyAccess",
  "createdate": "2026-06-02T20:42:11+00:00",
  "credentials_exposure": false,
  "data_access": false,
  "deprecated": false,
  "document": {
    "Statement": [
      {
        "Action": [
          "secretsmanager:GetSecretValue",
          "secretsmanager:DescribeSecret"
        ],
        "Effect": "Allow",
        "Resource": "arn:aws:secretsmanager:*:*:secret:*",
        "Sid": "SecretsManagerGetAndDescribeSecret"
      },
      {
        "Action": [
          "secretsmanager:BatchGetSecretValue",
          "secretsmanager:ListSecrets"
        ],
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "SecretsManagerBatchGetSecrets"
      },
      {
        "Action": [
          "kms:Decrypt"
        ],
        "Condition": {
          "StringLike": {
            "kms:EncryptionContext:SecretARN": "arn:aws:secretsmanager:*:*:secret:*",
            "kms:ViaService": "secretsmanager.*.amazonaws.com"
          }
        },
        "Effect": "Allow",
        "Resource": "arn:aws:kms:*:*:key/*",
        "Sid": "KMSDecryptKey"
      }
    ],
    "Version": "2012-10-17"
  },
  "effective_actions": [],
  "grantless": false,
  "malformed": false,
  "name": "AWSSecretsManagerClientReadOnlyAccess",
  "privesc": false,
  "resource_exposure": false,
  "undocumented_actions": false,
  "unknown_actions": [
    {
      "action": "secretsmanager:GetSecretValue",
      "condition": null
    },
    {
      "action": "secretsmanager:DescribeSecret",
      "condition": null
    },
    {
      "action": "secretsmanager:BatchGetSecretValue",
      "condition": null
    },
    {
      "action": "secretsmanager:ListSecrets",
      "condition": null
    },
    {
      "action": "kms:Decrypt",
      "condition": {
        "StringLike": {
          "kms:EncryptionContext:SecretARN": "arn:aws:secretsmanager:*:*:secret:*",
          "kms:ViaService": "secretsmanager.*.amazonaws.com"
        }
      }
    }
  ],
  "updatedate": "2026-06-02T20:42:11+00:00",
  "version": "v4"
}