      {
        "Action": [
          "ec2:CreateNetworkInterface"
        ],
        "Condition": {
          "StringEquals": {
            "aws:RequestTag/aws.cloudfront.vpcorigin": "enabled"
          }
        },
        "Effect": "Allow",
        "Resource": "arn:aws:ec2:*:*:network-interface/*",
        "Sid": "EC2Action1"
      },
      {
        "Action": [
          "ec2:CreateNetworkInterface"
        ],
        "Effect": "Allow",
        "Resource": [
          "arn:aws:ec2:*:*:subnet/*",
          "arn:aws:ec2:*:*:security-group/*"
        ],
        "Sid": "EC2Action2"
      },
      {
