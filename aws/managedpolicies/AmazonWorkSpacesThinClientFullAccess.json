{
  "access_levels": [],
  "arn": "arn:aws:iam::aws:policy/AmazonWorkSpacesThinClientFullAccess",
  "createdate": "2026-02-12T17:59:25+00:00",
  "credentials_exposure": false,
  "data_access": false,
  "deprecated": false,
  "document": {
    "Statement": [
      {
        "Action": [
          "thinclient:*"
        ],
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "AllowThinClientFullAccess"
      },
      {
        "Action": [
          "workspaces:DescribeConnectionAliases",
          "workspaces:DescribeWorkspaceDirectories"
        ],
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "AllowWorkSpacesAccess"
      },
      {
        "Action": [
          "workspaces-web:GetPortal",
          "workspaces-web:GetUserSettings",
          "workspaces-web:ListPortals"
        ],
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "AllowWorkSpacesSecureBrowserAccess"
      },
      {
        "Action": [
          "appstream:DescribeStacks"
        ],
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "AllowAppStreamAccess"
      },
      {
        "Action": [
          "iam:CreateServiceLinkedRole"
        ],
        "Condition": {
          "StringEquals": {
            "iam:AWSServiceName": "monitoring.thinclient.amazonaws.com"
          }
        },
        "Effect": "Allow",
        "Resource": "arn:aws:iam::*:role/aws-service-role/monitoring.thinclient.amazonaws.com/AWSServiceRoleForAmazonWorkSpacesThinClientMonitoring",
        "Sid": "AllowCreateServiceLinkedRole"
      }
    ],
    "Version": "2012-10-17"
  },
  "effective_actions": [],
  "grantless": false,
  "malformed": false,
  "name": "AmazonWorkSpacesThinClientFullAccess",
  "privesc": false,
  "resource_exposure": false,
  "undocumented_actions": false,
  "unknown_actions": [
    {
      "action": "thinclient:*",
      "condition": null
    },
    {
      "action": "workspaces:DescribeConnectionAliases",
      "condition": null
    },
    {
      "action": "workspaces:DescribeWorkspaceDirectories",
      "condition": null
    },
    {
      "action": "workspaces-web:GetPortal",
      "condition": null
    },
    {
      "action": "workspaces-web:GetUserSettings",
      "condition": null
    },
    {
      "action": "workspaces-web:ListPortals",
      "condition": null
    },
    {
      "action": "appstream:DescribeStacks",
      "condition": null
    },
    {
      "action": "iam:CreateServiceLinkedRole",
      "condition": {
        "StringEquals": {
          "iam:AWSServiceName": "monitoring.thinclient.amazonaws.com"
