          "application-autoscaling:PutScalingPolicy"
        ],
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "KeyspacesActionsNeededForSteadyStateReplication"
      },
      {
        "Action": [
          "cloudwatch:DeleteAlarms"
        ],
        "Effect": "Allow",
        "Resource": "arn:aws:cloudwatch:*:*:alarm:TargetTracking-*",
