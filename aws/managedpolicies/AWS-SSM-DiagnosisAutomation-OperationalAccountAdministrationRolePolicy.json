          }
        },
        "Effect": "Allow",
        "Resource": "arn:aws:iam::*:role/AWS-SSM-DiagnosisExecutionRole*",
        "Sid": "AllowAssumeDiagnosisExecutionRoleWithinOrg"
      }
    ],
    "Version": "2012-10-17"
  },
