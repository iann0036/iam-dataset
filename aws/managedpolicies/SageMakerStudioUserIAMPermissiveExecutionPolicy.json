        },
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "BedrockKms"
      },
      {
        "Action": [
          "kms:CreateGrant"
        ],
        "Condition": {
          "ForAllValues:StringEquals": {
            "kms:GrantOperations": [
              "Decrypt",
              "Encrypt",
              "GenerateDataKey",
              "GenerateDataKeyWithoutPlaintext",
              "RetireGrant"
