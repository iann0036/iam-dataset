        "Action": [
          "kms:Decrypt",
          "kms:Encrypt",
          "kms:GenerateDataKey",
          "kms:GenerateDataKeyWithoutPlaintext"
        ],
        "Condition": {
          "Null": {
            "kms:EncryptionContextKeys": "false"
          },
          "StringLike": {
            "kms:ViaService": "glue.*.amazonaws.com"
          }
        },
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "GlueKms"
