      {
        "Action": [
          "kms:CreateGrant"
        ],
        "Condition": {
          "ForAllValues:StringEquals": {
            "kms:GrantOperations": [
              "Encrypt",
              "Decrypt",
              "ReEncryptFrom",
              "ReEncryptTo",
              "GenerateDataKeyWithoutPlaintext",
              "GenerateDataKey",
              "DescribeKey",
              "RetireGrant",
              "CreateGrant"
