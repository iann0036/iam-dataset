          "Null": {
            "kms:EncryptionContextKeys": "false"
          },
          "StringLike": {
            "kms:ViaService": "sagemaker.*.amazonaws.com"
          }
        },
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "SageMakerKms"
