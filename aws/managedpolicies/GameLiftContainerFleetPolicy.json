{
  "access_levels": [],
  "arn": "arn:aws:iam::aws:policy/GameLiftContainerFleetPolicy",
  "createdate": "2026-02-12T17:57:58+00:00",
  "credentials_exposure": false,
  "data_access": false,
  "deprecated": false,
  "document": {
    "Statement": [
      {
        "Action": [
          "logs:CreateLogStream",
          "logs:PutLogEvents",
          "logs:PutRetentionPolicy"
        ],
        "Effect": "Allow",
        "Resource": "arn:aws:logs:*:*:log-group:gamelift-*:log-stream:*",
        "Sid": "WriteGameSessionLogsToLogStream"
      },
      {
        "Action": [
          "logs:CreateLogGroup"
        ],
        "Effect": "Allow",
        "Resource": "arn:aws:logs:*:*:log-group:gamelift-*",
        "Sid": "CreateLogGroupToStoreGameSessionLogs"
      },
      {
        "Action": [
          "s3:PutObject",
          "s3:GetBucketLocation"
        ],
        "Condition": {
          "StringEquals": {
            "s3:ResourceAccount": "${aws:PrincipalAccount}"
          }
        },
        "Effect": "Allow",
        "Resource": [
          "arn:aws:s3:::gamelift-*"
        ],
        "Sid": "WriteGameSessionLogsToS3Bucket"
      },
      {
        "Action": [
          "gamelift:GetComputeAuthToken"
        ],
        "Effect": "Allow",
        "Resource": [
          "arn:aws:gamelift:*:*:containerfleet/*"
        ],
        "Sid": "RetrieveComputeAuthToken"
      }
    ],
    "Version": "2012-10-17"
  },
  "effective_actions": [],
  "grantless": false,
  "malformed": false,
  "name": "GameLiftContainerFleetPolicy",
  "privesc": false,
  "resource_exposure": false,
  "undocumented_actions": false,
  "unknown_actions": [
    {
      "action": "logs:CreateLogStream",
      "condition": null
    },
    {
      "action": "logs:PutLogEvents",
      "condition": null
    },
    {
      "action": "logs:PutRetentionPolicy",
      "condition": null
    },
    {
      "action": "logs:CreateLogGroup",
      "condition": null
    },
    {
      "action": "s3:PutObject",
      "condition": {
        "StringEquals": {
          "s3:ResourceAccount": "${aws:PrincipalAccount}"
        }
      }
    },
    {
      "action": "s3:GetBucketLocation",
      "condition": {
        "StringEquals": {
          "s3:ResourceAccount": "${aws:PrincipalAccount}"
        }
      }
    },
    {
      "action": "gamelift:GetComputeAuthToken",
      "condition": null
    }
  ],
