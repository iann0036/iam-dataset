{
  "access_levels": [],
  "arn": "arn:aws:iam::aws:policy/AmazonS3TablesFullAccess",
  "createdate": "2026-02-12T18:00:31+00:00",
  "credentials_exposure": false,
  "data_access": false,
  "deprecated": false,
  "document": {
    "Statement": [
      {
        "Action": [
          "s3tables:*"
        ],
        "Effect": "Allow",
        "Resource": "*"
      },
      {
        "Action": [
          "iam:PassRole"
        ],
        "Condition": {
          "StringEquals": {
            "iam:PassedToService": [
              "replication.s3tables.amazonaws.com"
            ]
          }
        },
        "Effect": "Allow",
        "Resource": "*",
        "Sid": "PassRoleToS3TablesReplication"
      }
    ],
    "Version": "2012-10-17"
  },
  "effective_actions": [],
  "grantless": false,
  "malformed": false,
  "name": "AmazonS3TablesFullAccess",
  "privesc": false,
  "resource_exposure": false,
  "undocumented_actions": false,
  "unknown_actions": [
    {
      "action": "s3tables:*",
      "condition": null
    },
    {
      "action": "iam:PassRole",
      "condition": {
        "StringEquals": {
          "iam:PassedToService": [
            "replication.s3tables.amazonaws.com"
          ]
        }
      }
    }
  ],
