      },
      {
        "Action": [
          "iam:ListRoles"
        ],
        "Effect": "Allow",
        "Resource": "arn:aws:iam::*:*",
        "Sid": "cfflistroles"
      },
      {
        "Action": [
          "pricingplanmanager:AssociateResourcesToSubscription",
